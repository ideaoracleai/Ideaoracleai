// ═══════════════════════════════════════════════════════
// FIRESTORE SECURITY RULES for IdeaOracle.ai
// Firebase Console → Firestore Database → Rules tab mein paste karein
// ═══════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ────────────────────────────────
    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      // Admin check — admin UIDs list ya admin collection se
      return request.auth != null &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    // ── Users Collection ────────────────────────────────
    match /users/{uid} {
      // User apna document read/update kar sakta hai
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isLoggedIn() && isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // ── Credit History (subcollection) ────────────────
      match /creditHistory/{historyId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) || isAdmin();
        allow update, delete: if isAdmin();
      }

      // ── Ideas (subcollection) ─────────────────────────
      match /ideas/{ideaId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid) || isAdmin();
      }
    }

    // ── Coupons Collection ──────────────────────────────
    match /coupons/{couponId} {
      // Anyone logged in can read (to validate coupon)
      allow read: if isLoggedIn();
      // Only admin can create/update/delete
      allow write: if isAdmin();
    }

    // ── Admins Collection ───────────────────────────────
    match /admins/{uid} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── App Settings (global) ───────────────────────────
    match /settings/{settingId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
